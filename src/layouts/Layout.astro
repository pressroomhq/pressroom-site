---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Pressroom HQ — AI-Powered Content Operations',
  description = 'Pressroom HQ turns your company\'s GitHub activity, blog, and industry signals into a steady stream of content. Built for developer-focused SaaS teams.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[#0a0a0a] text-neutral-200 antialiased">
    <slot />
  </body>
</html>
