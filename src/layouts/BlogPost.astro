---
import Layout from './Layout.astro'

interface Props {
  title: string
  description: string
  date: string
  author?: string
  tags?: string[]
}

const { title, description, date, author, tags } = Astro.props
---

<Layout title={`${title} — Pressroom HQ`} description={description}>
  <header>
    <nav class="border-b border-neutral-800 px-6 py-3" aria-label="Main navigation">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="text-[#ffb000] font-semibold tracking-tight text-sm" aria-label="Pressroom HQ home">PRESSROOM HQ</a>
        <div class="flex items-center gap-6 text-xs">
          <a href="/docs" class="text-[#7a5a00] hover:text-[#ffb000] transition-colors uppercase tracking-wide">Docs</a>
          <a href="/blog" class="text-[#7a5a00] hover:text-[#ffb000] transition-colors uppercase tracking-wide">Blog</a>
        </div>
      </div>
    </nav>
  </header>

  <main class="px-6 py-12">
    <article class="max-w-3xl mx-auto">
      <div class="mb-8">
        <a href="/blog" class="text-xs text-[#7a5a00] hover:text-[#ffb000] transition-colors uppercase tracking-wide mb-4 inline-block">&larr; Back to blog</a>
        <h1 class="text-2xl sm:text-3xl font-bold text-white leading-snug mb-3">{title}</h1>
        <div class="flex flex-wrap items-center gap-4 text-xs text-neutral-500">
          <time datetime={date}>{date}</time>
          {author && <span>{author}</span>}
          {tags && tags.length > 0 && (
            <div class="flex gap-2">
              {tags.map((tag) => (
                <span class="text-[#7a5a00]">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>

  <footer class="border-t border-neutral-800 px-6 py-6">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-xs text-neutral-600">
      <span class="text-[#7a5a00]">PRESSROOM HQ</span>
      <nav aria-label="Footer navigation" class="flex gap-6">
        <a href="/docs" class="hover:text-neutral-400 transition-colors">Docs</a>
        <a href="/blog" class="hover:text-neutral-400 transition-colors">Blog</a>
        <a href="https://app.pressroomhq.com" class="hover:text-neutral-400 transition-colors">App</a>
        <a href="https://github.com/pressroomhq" class="hover:text-neutral-400 transition-colors">GitHub</a>
      </nav>
      <span>2026 Pressroom HQ</span>
    </div>
  </footer>
</Layout>
