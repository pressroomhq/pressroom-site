---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Pressroom HQ" description="Page not found.">
  <main class="px-6 py-24 text-center">
    <div class="max-w-md mx-auto">
      <div class="text-xs text-[#7a5a00] mb-4 tracking-wide">ERR / 404</div>
      <h1 class="text-2xl font-bold text-white mb-3">Page not found</h1>
      <p class="text-neutral-500 text-xs mb-6">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="text-[#ffb000] text-xs hover:text-[#e09e00] transition-colors uppercase tracking-wide">Back to home</a>
    </div>
  </main>
</Layout>
